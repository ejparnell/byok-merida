NOTION_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id
NOTION_RESUME_DATABASE_ID=your_resume_database_id
NOTION_NOTES_DATABASE_ID=your_notes_database_id
CAPTURE_TOKEN=
EXTENSION_ORIGIN=chrome-extension://your-extension-id
DEEPSEEK_API_KEY=your_deepseek_api_key
# Supported DeepSeek model IDs: deepseek-v4-flash, deepseek-v4-pro.
# Do not use deprecated aliases deepseek-chat or deepseek-reasoner.

API_HOST=127.0.0.1
API_PORT=8000
WEB_ORIGIN=http://127.0.0.1:5173
ANALYSIS_MODEL=deepseek-v4-flash
RESUME_MODEL=deepseek-v4-pro
EXPORT_PATH=app-data/export
RECOVERY_JOURNAL_PATH=app-data/recovery/effects.json

{
  "manifest_version": 3,
  "name": "Merida Application Capture",
  "version": "1.0.0",
  "description": "Review-first Application capture for the local Merida workflow.",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_title": "Open Merida Application Capture" },
  "side_panel": { "default_path": "index.html" }
}

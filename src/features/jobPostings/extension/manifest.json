{
  "manifest_version": 3,
  "name": "Merida Job Capture",
  "description": "Capture a job posting into the configured Notion database through the local Merida backend.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/bownarrow-16.png",
    "32": "icons/bownarrow-32.png",
    "48": "icons/bownarrow-48.png",
    "128": "icons/bownarrow-128.png"
  },
  "permissions": ["activeTab", "scripting", "sidePanel", "storage"],
  "host_permissions": ["http://localhost:*/*", "http://127.0.0.1:*/*"],
  "action": {
    "default_title": "Open job capture panel",
    "default_icon": {
      "16": "icons/bownarrow-16.png",
      "32": "icons/bownarrow-32.png",
      "48": "icons/bownarrow-48.png",
      "128": "icons/bownarrow-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_page": "options.html"
}
